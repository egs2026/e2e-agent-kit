{
  "name": "e2e-agent-kit",
  "version": "0.2.0",
  "private": true,
  "description": "VPS-ready E2E agent starter package",
  "scripts": {
    "bootstrap": "bash e2e/scripts/bootstrap.sh",
    "smoke": "bash e2e/scripts/run-smoke.sh",
    "smoke:api": "bash e2e/scripts/run-api-smoke.sh",
    "regression:api": "bash e2e/scripts/run-api-regression.sh",
    "regression": "bash e2e/scripts/run-regression.sh",
    "regression:p2": "bash e2e/scripts/run-p2.sh",
    "security": "bash e2e/scripts/run-security.sh",
    "e2e:run": "bash e2e/scripts/run-by-priority.sh",
    "ai:generate-spec": "node e2e/scripts/ai-generate-spec.mjs",
    "ai:refine-spec": "node e2e/scripts/ai-refine-spec.mjs",
    "mcp:daily-gate": "bash e2e/scripts/run-daily-gate.sh",
    "prod:status": "bash e2e/scripts/prod-readiness-status.sh",
    "deploy:frontend": "bash deploy/deploy-frontend-wrapper.sh",
    "dashboard": "bash e2e/scripts/dashboard.sh",
    "check:endpoints": "bash e2e/scripts/check-endpoints.sh",
    "report:serve": "python3 -m http.server 8787 --directory reports/e2e",
    "setup:playwright": "npx playwright install chromium"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "playwright": "^1.53.2"
  }
}
